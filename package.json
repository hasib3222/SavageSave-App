{
  "name": "turbonest",
  "version": "1.0.0",
  "description": "TurboNest — a world-class premium desktop download manager with multi-connection acceleration, video quality picker, smart scheduler, and built-in terminal.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development ELECTRON_RUN_AS_NODE= electron .",
    "build": "vite build",
    "start": "electron ."
  },
  "author": "Senior SWE",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^12.38.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.9",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "vite": "^5.2.13",
    "wait-on": "^7.2.0"
  }
}
